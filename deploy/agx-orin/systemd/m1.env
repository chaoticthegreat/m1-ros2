# M1 autostart environment -- sourced by the systemd units.
# Install to /etc/m1/m1.env and EDIT the paths/args for your machine.
# See DEPLOY_AGX_ORIN.md "Phase 11".

# Absolute path to the cloned repo and its colcon workspace.
M1_REPO=/home/USER/m1-ros2-setup
M1_WS=/home/USER/m1-ros2-setup/ros2_ws

# The user the stack runs as (must own the workspace + be in groups for CAN/serial).
M1_USER=USER

# ROS distro setup to source.
ROS_SETUP=/opt/ros/jazzy/setup.bash

# CAN interface + mode for the arms/lift bus.
CAN_IFACE=can0
CAN_FD=true                 # true -> CAN-FD 1M/5M ; false -> classic CAN 1M

# Path to the motor map authored by m1_hwconfig (Phase 7).
MOTOR_MAP=/home/USER/.config/m1/motor_map.yaml

# Extra args appended to the hardware launch. use_base:=true to also start the
# AgileX base bridges (needs the base driver + a separate CAN adapter, Phase 9).
M1_LAUNCH_ARGS=use_mock:=false use_rviz:=false

# DDS scope. LOCALHOST_ONLY=1 if everything runs on the Orin; comment it out (or
# set ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET) if off-board viz must reach the Orin.
ROS_LOCALHOST_ONLY=1
# RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
